{
  "swagger": "2.0",
  "host": "127.0.0.1:8000",
  "basePath": "/",
  "info": {
    "version": "1.0.0",
    "title": "Events Manager App API Specification",
    "description": "API specification for the Event Manager backend. Users can register, create events, book and cancel bookings, view event details, and submit feedback. Protected APIs use JWT bearer authentication."
  },
  "schemes": [
    "http",
    "https"
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "securityDefinitions": {
    "Bearer": {
      "type": "apiKey",
      "name": "Authorization",
      "in": "header",
      "description": "JWT access token. Use the format: Bearer <access_token>"
    }
  },
  "definitions": {
    "TokenObtainRequest": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        }
      },
      "required": [
        "username",
        "password"
      ]
    },
    "TokenObtainResponse": {
      "type": "object",
      "properties": {
        "refresh": {
          "type": "string"
        },
        "access": {
          "type": "string"
        }
      }
    },
    "TokenRefreshRequest": {
      "type": "object",
      "properties": {
        "refresh": {
          "type": "string"
        }
      },
      "required": [
        "refresh"
      ]
    },
    "TokenRefreshResponse": {
      "type": "object",
      "properties": {
        "access": {
          "type": "string"
        }
      }
    },
    "CreateUserRequest": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": [
            "organizer",
            "attendee"
          ]
        },
        "phone_number": {
          "type": "string"
        }
      },
      "required": [
        "username",
        "password",
        "email",
        "role",
        "phone_number"
      ]
    },
    "CreateEventRequest": {
      "type": "object",
      "properties": {
        "event_title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "start_date": {
          "type": "string",
          "format": "date-time"
        },
        "end_date": {
          "type": "string",
          "format": "date-time"
        },
        "venue": {
          "type": "string"
        },
        "is_paid": {
          "type": "boolean"
        },
        "maximum_attendees": {
          "type": "integer",
          "format": "int64"
        },
        "ticket_price": {
          "type": "number",
          "format": "float"
        }
      },
      "required": [
        "event_title",
        "description",
        "start_date",
        "end_date",
        "venue",
        "is_paid",
        "maximum_attendees",
        "ticket_price"
      ]
    },
    "CreateBookingRequest": {
      "type": "object",
      "properties": {
        "event_id": {
          "type": "integer",
          "format": "int64"
        }
      },
      "required": [
        "event_id"
      ]
    },
    "CancelBookingRequest": {
      "type": "object",
      "properties": {
        "booking_id": {
          "type": "integer",
          "format": "int64"
        }
      },
      "required": [
        "booking_id"
      ]
    },
    "FeedbackRequest": {
      "type": "object",
      "properties": {
        "rating": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "comment": {
          "type": "string"
        },
        "event_id": {
          "type": "integer",
          "format": "int64"
        }
      },
      "required": [
        "rating",
        "comment",
        "event_id"
      ]
    },
    "SuccessWithIdResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        },
        "id": {
          "type": "integer",
          "format": "int64"
        }
      }
    },
    "MessageResponse": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string"
        }
      }
    },
    "OrganizerDetails": {
      "type": "object",
      "properties": {
        "organizer_id": {
          "type": "integer",
          "format": "int64"
        },
        "organizer_email": {
          "type": "string",
          "format": "email"
        },
        "organizer_name": {
          "type": "string"
        }
      }
    },
    "AttendeeDetails": {
      "type": "object",
      "properties": {
        "attendee_id": {
          "type": "integer",
          "format": "int64"
        },
        "attendee_email": {
          "type": "string",
          "format": "email"
        },
        "attendee_name": {
          "type": "string"
        }
      }
    },
    "TicketDetails": {
      "type": "object",
      "properties": {
        "ticket_price": {
          "type": "number",
          "format": "float"
        }
      }
    },
    "EventDetailsResponse": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "format": "int64"
        },
        "event_title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "start_date": {
          "type": "string",
          "format": "date-time"
        },
        "end_date": {
          "type": "string",
          "format": "date-time"
        },
        "venue": {
          "type": "string"
        },
        "maximum_attendees": {
          "type": "integer",
          "format": "int64"
        },
        "organizer_details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/OrganizerDetails"
          }
        },
        "attendee_details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AttendeeDetails"
          }
        },
        "booking_cancelled_users": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AttendeeDetails"
          }
        },
        "booking_pending_users": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AttendeeDetails"
          }
        },
        "ticket_details": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/TicketDetails"
          }
        }
      }
    }
  },
  "paths": {
    "/api/token/": {
      "post": {
        "summary": "Get JWT tokens",
        "description": "Returns access and refresh tokens for a valid username and password.",
        "operationId": "token_obtain_pair",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TokenObtainRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JWT tokens generated successfully",
            "schema": {
              "$ref": "#/definitions/TokenObtainResponse"
            }
          },
          "401": {
            "description": "Invalid credentials"
          }
        }
      }
    },
    "/api/token/refresh/": {
      "post": {
        "summary": "Refresh JWT access token",
        "description": "Returns a new access token for a valid refresh token.",
        "operationId": "token_refresh",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/TokenRefreshRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Access token refreshed successfully",
            "schema": {
              "$ref": "#/definitions/TokenRefreshResponse"
            }
          },
          "401": {
            "description": "Invalid or expired refresh token"
          }
        }
      }
    },
    "/event/user/": {
      "post": {
        "summary": "Register user",
        "description": "Creates a new user. This endpoint is public.",
        "operationId": "register_user",
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "User details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateUserRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "User created successfully",
            "schema": {
              "$ref": "#/definitions/SuccessWithIdResponse"
            }
          },
          "400": {
            "description": "Invalid data or user already exists",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          }
        }
      }
    },
    "/event/create/": {
      "post": {
        "summary": "Create event",
        "description": "Creates a new event for the authenticated organizer. The organizer id is taken from the JWT user, not from the request body.",
        "operationId": "create_event",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Event details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateEventRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Event created successfully",
            "schema": {
              "$ref": "#/definitions/SuccessWithIdResponse"
            }
          },
          "400": {
            "description": "Invalid event data or organizer not found",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          },
          "401": {
            "description": "Authentication credentials were not provided or are invalid"
          },
          "403": {
            "description": "Authenticated user is not an organizer",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          }
        }
      }
    },
    "/event/booking/": {
      "post": {
        "summary": "Create booking",
        "description": "Books the authenticated attendee for an event. The attendee id is taken from the JWT user, not from the request body.",
        "operationId": "event_booking",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Booking details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CreateBookingRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking successful",
            "schema": {
              "$ref": "#/definitions/SuccessWithIdResponse"
            }
          },
          "400": {
            "description": "Invalid data, invalid event, invalid attendee, already booked, or tickets full",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          },
          "401": {
            "description": "Authentication credentials were not provided or are invalid"
          }
        }
      }
    },
    "/event/cancel-booking/": {
      "post": {
        "summary": "Cancel booking",
        "description": "Cancels a booking for the authenticated attendee.",
        "operationId": "cancel_booking",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Booking cancellation details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/CancelBookingRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking cancelled successfully",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          },
          "400": {
            "description": "Invalid data, invalid attendee, or invalid booking id",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          },
          "401": {
            "description": "Authentication credentials were not provided or are invalid"
          }
        }
      }
    },
    "/event/get-event/{event_id}/": {
      "get": {
        "summary": "Get event details",
        "description": "Returns event details, organizer details, attendees grouped by booking status, and ticket details.",
        "operationId": "get_event_details",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "name": "event_id",
            "in": "path",
            "description": "Event id",
            "required": true,
            "type": "integer",
            "format": "int64"
          }
        ],
        "responses": {
          "200": {
            "description": "Event details fetched successfully",
            "schema": {
              "$ref": "#/definitions/EventDetailsResponse"
            }
          },
          "400": {
            "description": "Event not found",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          },
          "401": {
            "description": "Authentication credentials were not provided or are invalid"
          }
        }
      }
    },
    "/event/feedback/": {
      "post": {
        "summary": "Create or update feedback",
        "description": "Creates feedback for the authenticated attendee's booked event. If feedback already exists for that attendee and event, it is updated.",
        "operationId": "give_feedback",
        "security": [
          {
            "Bearer": []
          }
        ],
        "parameters": [
          {
            "in": "body",
            "name": "body",
            "description": "Feedback details",
            "required": true,
            "schema": {
              "$ref": "#/definitions/FeedbackRequest"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Feedback saved successfully",
            "schema": {
              "$ref": "#/definitions/SuccessWithIdResponse"
            }
          },
          "400": {
            "description": "Invalid user, invalid event, invalid booking details, or invalid feedback data",
            "schema": {
              "$ref": "#/definitions/MessageResponse"
            }
          },
          "401": {
            "description": "Authentication credentials were not provided or are invalid"
          }
        }
      }
    }
  }
}
